{
  "name": "nrf-journey-tests",
  "version": "0.0.0",
  "type": "module",
  "description": "",
  "engines": {
    "node": ">=22.13.1"
  },
  "author": "Defra DDTS",
  "license": "OGL-UK-3.0",
  "scripts": {
    "clean": "rm -rf allure-results allure-report FAILED",
    "test:e2e": "npm run clean && cucumber-js",
    "test:e2e:local": "npm run clean && BASE_URL=http://localhost:3000 cucumber-js",
    "test:e2e:debug": "npm run clean && E2E_HEADFUL=true BASE_URL=http://localhost:3000 cucumber-js",
    "test:localstack": "docker compose up --wait --quiet-pull -d && npm run test:e2e",
    "compose:down": "docker compose down --remove-orphans",
    "format": "prettier --write 'test/**/*.js' '**/*.{js,md,json,config.js}'",
    "format:check": "prettier --check 'test/**/*.js' '**/*.{js,md,json,config.js}'",
    "git:pre-commit-hook": "npm run format:check && npm run lint",
    "git:pre-push-hook": "npm audit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "postinstall": "npm run setup:husky && npx playwright install chromium && npm audit",
    "setup:husky": "node -e \"try { (await import('husky')).default() } catch (e) { if (e.code !== 'ERR_MODULE_NOT_FOUND') throw e }\" --input-type module",
    "report": "allure generate allure-results --single-file --clean",
    "report:publish": "npm run report; ./bin/publish-tests.sh"
  },
  "dependencies": {
    "@cucumber/cucumber": "11.3.0",
    "allure-commandline": "2.32.0",
    "allure-cucumberjs": "3.2.0",
    "playwright": "1.58.2",
    "undici": "7.24.6"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-config-standard": "17.1.0",
    "eslint-plugin-prettier": "5.1.3",
    "husky": "9.1.7",
    "prettier": "3.4.2"
  }
}
